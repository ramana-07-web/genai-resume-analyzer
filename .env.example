# ─── Gemini AI (Required) ───
# Get your free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── Affinda Resume Parser (Optional) ───
# If not set, the app uses the built-in pypdf fallback parser.
# Sign up: https://api.affinda.com/
AFFINDA_API_KEY=your_affinda_api_key_here
AFFINDA_WORKSPACE=your_workspace_id_here

# ─── Flask (Optional) ───
FLASK_ENV=production
PORT=5000
